{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "typeRoots": ["./types"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "sourceMap": true,
    "paths": {
      "mod.json": ["./mod.json"],
      "@/*": ["./src/*"]
    }
  }
}
